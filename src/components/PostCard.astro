---
import type { MediumPost } from '../lib/medium';
import { formatPostDate } from '../lib/medium';

type Props = {
  post: MediumPost;
};

const { post } = Astro.props;
---

<article class="dev-card group overflow-hidden">
  {
    post.image && (
      <a href={post.url} target="_blank" rel="noopener noreferrer">
        <img
          src={post.image}
          alt=""
          loading="lazy"
          class="aspect-[2/1] w-full object-cover opacity-90 transition group-hover:opacity-100"
        />
      </a>
    )
  }
  <div class="p-5">
    <time class="mono text-xs text-[var(--color-muted)]">{formatPostDate(post.date)}</time>
    <h3 class="mt-2 text-lg font-semibold leading-snug">
      <a href={post.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)]">
        {post.title}
      </a>
    </h3>
    {post.excerpt && <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">{post.excerpt}</p>}
    {
      post.categories.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.categories.slice(0, 4).map((cat) => (
            <span class="mono rounded border border-[var(--color-border)] px-2 py-0.5 text-[10px] text-[var(--color-muted)]">
              {cat}
            </span>
          ))}
        </div>
      )
    }
    <a
      href={post.url}
      target="_blank"
      rel="noopener noreferrer"
      class="mono mt-4 inline-block text-xs text-[var(--color-accent)] hover:underline"
    >
      read on medium →
    </a>
  </div>
</article>
