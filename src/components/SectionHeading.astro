---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
};

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl border-l-2 border-[var(--color-accent)] pl-5">
  {eyebrow && <p class="section-label mb-2">{eyebrow}</p>}
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
  {description && <p class="mt-4 text-[17px] leading-8 text-[var(--color-muted)]">{description}</p>}
</div>
