---
import BaseLayout from '../layouts/BaseLayout.astro';
import Terminal from '../components/Terminal.astro';
import { site } from '../config/site';

const skills = [
  'Go',
  'Node.js',
  'TypeScript',
  'Kafka',
  'Debezium',
  'RabbitMQ',
  'Redis',
  'MongoDB',
  'PostgreSQL',
  'Express',
  'Fastify',
  'Docker',
  'Microservices',
  'Developer Tooling',
];
---

<BaseLayout title={site.fullName} description={site.description}>
  <section class="page-shell py-14 sm:py-20">
    <div class="mx-auto max-w-[810px]">
      <div class="fade-up mb-10 text-center">
        <img
          src="/images/avatar.jpg"
          alt={site.fullName}
          width="120"
          height="120"
          class="mx-auto h-[120px] w-[120px] rounded-full border-2 border-[var(--color-border)] object-cover"
        />
        <h1 class="mt-6 text-4xl font-bold tracking-tight sm:text-5xl">{site.name}</h1>
        <p class="mt-3 text-lg text-[var(--color-muted)]">{site.title} · {site.location}</p>
      </div>

      <div class="fade-up-delay mb-10">
        <p class="text-center text-[17px] leading-8 text-[var(--color-muted)]">{site.bio}</p>
      </div>

      <div class="fade-up-delay">
        <Terminal />
      </div>
    </div>

    <div class="mx-auto mt-20 max-w-[960px] border-t border-[var(--color-border)] pt-16">
      <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="space-y-6 text-[17px] leading-8 text-[var(--color-muted)]">
          <p>
            I live in İzmir and have been building software since {site.githubSince}.
          </p>
          <p>
            Most of my work is backend — building and maintaining the systems behind the scenes.
            I enjoy learning how things work and making complicated problems a little clearer.
          </p>
          <p class="border-l-2 border-[var(--color-accent)] pl-4 text-[var(--color-ink)] italic">
            Happiness should be a function without any parameters.
          </p>
        </div>

        <aside class="dev-card h-fit p-5">
          <h2 class="mono text-sm font-semibold uppercase tracking-wider text-[var(--color-accent)]">here</h2>
          <dl class="mt-5 space-y-4 text-sm">
            <div>
              <dt class="text-[var(--color-muted)]">location</dt>
              <dd class="mt-1 font-medium">{site.location}</dd>
            </div>
            <div>
              <dt class="text-[var(--color-muted)]">email</dt>
              <dd class="mt-1">
                <a href={`mailto:${site.email}`} class="link-accent">{site.email}</a>
              </dd>
            </div>
          </dl>
        </aside>
      </div>

      <div class="mt-16">
        <h2 class="text-2xl font-bold">Tools I reach for</h2>
        <div class="mt-5 flex flex-wrap gap-2">
          {
            skills.map((skill) => (
              <span class="mono rounded border border-[var(--color-border)] px-2.5 py-1 text-xs text-[var(--color-muted)]">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
