---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import RepoCard from '../components/RepoCard.astro';
import { site } from '../config/site';
import { fetchGitHubRepos } from '../lib/github';

const repos = await fetchGitHubRepos(site.github);
const topRepos = repos.slice(0, 24);
---

<BaseLayout
  title="Open Source"
  description="Open source repositories by Erdem Köşk — Go, Node.js, and TypeScript projects on GitHub."
>
  <section class="page-shell py-14 sm:py-18">
    <SectionHeading
      eyebrow="open source"
      title="Code on GitHub"
      description={`${repos.length} public repositories — tools, boilerplates, and experiments.`}
    />

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        href={site.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="mono inline-flex items-center rounded-md border border-[var(--color-accent)] px-4 py-2 text-sm text-[var(--color-accent)] hover:bg-[var(--color-accent-dim)]"
      >
        github.com/{site.github} →
      </a>
      <span class="mono text-xs text-[var(--color-muted)]">synced at build</span>
    </div>

    {
      topRepos.length > 0 ? (
        <div class="mt-12 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
          {topRepos.map((repo) => (
            <RepoCard repo={repo} />
          ))}
        </div>
      ) : (
        <p class="mt-12 text-[var(--color-muted)]">
          Repos could not be loaded. Visit <a href={site.social.github} class="link-accent">GitHub</a>.
        </p>
      )
    }
  </section>
</BaseLayout>
